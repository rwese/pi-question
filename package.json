{
  "name": "@rwese/pi-question",
  "version": "0.2.0",
  "description": "Unified question tool for pi coding agent - single or multi-question interactions with optional notes and custom input support",
  "type": "module",
  "main": "./extensions/index.ts",
  "pi": {
    "extensions": ["./extensions"]
  },
  "keywords": ["pi-package", "pi-extension", "question", "ui", "interactive"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rwese/pi-question"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.4.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint extensions/",
    "lint:fix": "eslint extensions/ --fix",
    "format": "prettier --write extensions/",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test"
  }
}