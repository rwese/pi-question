{
  "name": "@rwese/pi-question",
  "version": "2.6.0",
  "description": "Unified question tool for pi coding agent - single or multi-question interactions with optional notes and custom input support",
  "type": "module",
  "main": "./extensions/index.ts",
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "question",
    "ui",
    "interactive"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rwese/pi-question"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lockfile-lint": "^5.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "extensions/**/*.ts": [
      "prettier --write",
      "eslint --fix",
      "prettier --check"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "lint:lockfile": "lockfile-lint --path package-lock.json --type npm --validate-https --allowed-hosts registry.npmjs.org",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint extensions/",
    "lint:fix": "eslint extensions/ --fix",
    "format": "prettier --write extensions/",
    "typecheck": "tsgo --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "scan:secrets": "gitleaks detect --source . --verbose",
    "scan:secrets:deep": "trufflehog filesystem .",
    "scan:secrets:git": "trufflehog git https://github.com/rwese/pi-question.git --no-update",
    "scan:secrets:ci": "gitleaks detect --source . --verbose --no-color",
    "secret-allow": "gitleaks allow --skip ''",
    "version:patch": "npm version patch -m 'chore: Bump patch version' && git push && git push --tags",
    "version:minor": "npm version minor -m 'feat: Bump minor version' && git push && git push --tags",
    "version:major": "npm version major -m 'BREAKING CHANGE: Major version bump' && git push && git push --tags",
    "release:patch": "npm run validate && npm run version:patch",
    "release:minor": "npm run validate && npm run version:minor",
    "release:major": "npm run validate && npm run version:major"
  }
}
